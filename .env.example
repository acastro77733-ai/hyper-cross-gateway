# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# VITE_MAGIC_PUBLISHABLE_KEY: Your Magic.link publishable API key
VITE_MAGIC_PUBLISHABLE_KEY="pk_live_..."

# VITE_WALLETCONNECT_PROJECT_ID: Your WalletConnect Project ID (from cloud.walletconnect.com)
VITE_WALLETCONNECT_PROJECT_ID="5bfa9c8d646441ac48e1e416de0b7773"

# KALEIDO_RPC_URL: Server-only Kaleido JSON-RPC endpoint URL used by backend telemetry.
# Do not expose authenticated Kaleido RPC credentials through Vite env vars.
KALEIDO_RPC_URL="https://..."

# KALEIDO_RPC_BASIC_USERNAME / KALEIDO_RPC_BASIC_PASSWORD: Optional server-only basic auth credentials.
KALEIDO_RPC_BASIC_USERNAME=""
KALEIDO_RPC_BASIC_PASSWORD=""

# KALEIDO_RPC_BEARER_TOKEN: Optional server-only bearer token if your Kaleido RPC requires it.
KALEIDO_RPC_BEARER_TOKEN=""

# KALEIDO_RPC_API_KEY_HEADER_NAME / KALEIDO_RPC_API_KEY: Optional server-only custom header auth.
KALEIDO_RPC_API_KEY_HEADER_NAME=""
KALEIDO_RPC_API_KEY=""

# VITE_KALEIDO_PUBLIC_RPC_URL: Optional public non-sensitive RPC URL used only for wallet_addEthereumChain.
# Leave empty if you do not want to expose a public wallet RPC endpoint.
VITE_KALEIDO_PUBLIC_RPC_URL=""

# VITE_KALEIDO_CHAIN_ID: Kaleido network chain ID (decimal)
VITE_KALEIDO_CHAIN_ID="13370"

# VITE_KALEIDO_CHAIN_NAME: Friendly network name shown in wallet UIs
VITE_KALEIDO_CHAIN_NAME="Kaleido EVM"

# VITE_KALEIDO_CURRENCY_SYMBOL: Native token symbol for the Kaleido chain
VITE_KALEIDO_CURRENCY_SYMBOL="ETH"

# VITE_KALEIDO_EXPLORER_URL: Explorer URL for transaction drill-down
VITE_KALEIDO_EXPLORER_URL="https://..."

# MAGIC_SECRET_KEY: Your Magic.link secret API key (Server-side only)
MAGIC_SECRET_KEY="sk_live_..."

# MAGIC_IDENTITY_PROVIDER: Configuration for Magic Labs Identity Provider
MAGIC_ISSUER="https://your-auth-provider.com"
MAGIC_AUDIENCE="your-app-audience"
MAGIC_JWKS_URI="https://your-auth-provider.com/.well-known/jwks.json"
